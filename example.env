# ====================================================
#                  Environment Variables
# ====================================================

# **Important:**
# - Replace placeholder values (e.g., YourTelegramBotToken) with your actual configuration.
# - Do NOT share your `.env` file publicly as it contains sensitive information.
# - Consider adding `.env` to your `.gitignore` to prevent it from being committed to version control.

# --------------------- Telegram Configuration ---------------------
# Configuration related to Telegram bot notifications.

# Token for your Telegram bot (obtained from BotFather)
TELEGRAM_BOT_TOKEN=YourTelegramBotToken

# Telegram Chat ID where notifications will be sent
# Use tools like @userinfobot on Telegram to find your Chat ID (User ID)
CHAT_ID=YourTelegramChatID

# --------------------- LNbits Configuration ---------------------
# Configuration for integrating with LNbits, a Lightning Network wallet.

# Read-only API key for retrieving wallet balances and authenticating webhooks
LNBITS_READONLY_API_KEY=YourLNbitsReadOnlyAPIKEY

# Base URL of your LNbits instance (ensure it includes the protocol, e.g., https://)
LNBITS_URL=https://lnbits.yourdomain.com

# Custom name for your LNbits instance (used in Telegram notifications)
# Enclose in quotes if the name contains spaces.
INSTANCE_NAME="Your Instance Name"

# --------------------- Authentication Configuration ---------------------
# Configuration for admin access and authentication.

# Admin password for accessing the settings page
# Choose a strong, secure password.
ADMIN_PASSWORD=YourSecurePassword

# Secret Key for Flask Sessions
# Generate a strong secret key for securing sessions.
SECRET_KEY=YourSecureSecretKey

# --------------------- Notification Settings ---------------------
# Settings to control how and when notifications are sent.

# Threshold for balance changes in Satoshis to trigger a notification.
# Default is 1 Sat. Set higher to reduce the number of notifications.
BALANCE_CHANGE_THRESHOLD=1

# Number of latest transactions to fetch for notifications.
# Default is 21. Duplicates will be ignored.
LATEST_TRANSACTIONS_COUNT=21

# --------------------- Scheduler Intervals ---------------------
# Configuration for how often certain tasks run.

# Interval in seconds for fetching the latest payments.
# Default: 60 seconds (1 minute).
# Set to 0 to disable fetching payments.
PAYMENTS_FETCH_INTERVAL=60

# --------------------- Overwatch Configuration ---------------------
# Configuration for Overwatch, a tool for monitoring transactions.

# URL for Overwatch to view transactions and other details.
# Uncomment and set if using Overwatch.
#OVERWATCH_URL=YourOverwatchURL

# --------------------- Live-Ticker Configuration ---------------------
# Configuration for the Live-Ticker dashboard that displays donations.

# URL for the Live-Ticker dashboard page.
# Uncomment and set if using Live-Ticker.
#DONATIONS_URL=YourLiveTickerPageURL

# --------------------- LiveTicker Parameters ---------------------
# Additional parameters for Live-Ticker functionality.

# ID from LNURLP (LNURL Pay) for handling donations.
LNURLP_ID=YourLNURPID

# Threshold for highlighting large donations (amount in Satoshis).
HIGHLIGHT_THRESHOLD=2100

# URL for additional information about the reason for fundraising/donations.
# This could link to a social media post, your homepage, or any relevant page.
INFORMATION_URL=YourInformationPageURL

# --------------------- Flask Server Configuration ---------------------
# Configuration for running the Flask web server.

# Host address for the Flask server.
# Use '0.0.0.0' to make the server externally visible.
APP_HOST=127.0.0.1

# Port number for the Flask server.
# Ensure the port is open and not used by other services.
APP_PORT=5009

# --------------------- File Paths ---------------------
# Paths to various files used by the application.

# File to track processed payments.
PROCESSED_PAYMENTS_FILE=processed_payments.txt

# File to store the current balance.
CURRENT_BALANCE_FILE=current-balance.txt

# File to store donation information.
DONATIONS_FILE=donations.json

# Path to the file containing forbidden words.
# These words may be filtered out from memos or messages to maintain appropriate content.
FORBIDDEN_WORDS_FILE=forbidden_words.txt

# --------------------- User Configuration ---------------------
# File to store LN-Auth user information
USERS_FILE=users.json
